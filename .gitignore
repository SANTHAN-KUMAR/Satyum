# --- Local agent / editor config (never shared) ---
.claude/settings.local.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.hypothesis/

# --- Secrets & environment (CLAUDE.md §10 — never commit secrets/keys) ---
.env
.env.*
!.env.example
# Private keys only. PUBLIC trust roots (*.pem/*.crt/*.cer/*.der) DO ship in-repo per §10 —
# the demo CA *private* key lives outside the repo (scratchpad), never here.
*.key
*_key.pem
*private*.pem
*.pfx
*.p12
# Operator-provided production trust anchors (e.g. the real CCA-India root) are deployment config,
# not source — keep them out of git. The dir is kept via .gitkeep for the compose mount.
deploy/trust-anchors/*
!deploy/trust-anchors/.gitkeep

# --- Node / frontend (frontend/.gitignore also covers these; belt-and-suspenders) ---
node_modules/
*.tsbuildinfo
.vite/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.log
*.swp

# --- Generated Corpus Data ---
samples/mass_corpus/
samples/hard/
652591331-Canara-Bank-Statement.pdf
804153748-Statement.pdf
aadhars/
.agents/

# --- Confidential real-life PII documents — NEVER commit (real Aadhaar/PAN/bank/IT of a real person) ---
Real_life_docs/
.Real_life_docs/
**/Real_life_docs/

# --- Local Ollama VLM model blobs (multi-GB; pulled for self-hosted/offline reading) — never commit ---
.ollama_models/
.ollama/

# --- VLM extraction cache — caches full extracted document content (names, addresses, account
# numbers) from whatever was actually run locally, which includes real personal test documents.
# Never commit: this is derived PII, not a project artifact. ---
backend/.vlm_cache/

# --- Personal real documents used for local testing — NOT synthetic; keep out of git (PII) ---
PAN/
Santhan_bank_statement_forged.pdf
canara_epassbook_2026.pdf
demo_bundles/01_User_Tollways_Match/

# --- Local scratch/debug scripts and archives — never project artifacts ---
satyum-source.zip
test_ds.py
test_qwen_groq.py
.claude/
Videos/

# --- Internal working docs — kept locally, not part of the public repo ---
PITCH-SCRIPT.md
DESIGN.md
PROBLEM STATEMENT SuRaksha.txt
hackathon_submission.md
