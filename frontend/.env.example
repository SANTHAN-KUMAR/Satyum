# Satyum frontend environment (copy to .env.local; .env.local is gitignored).
# No backend URL is ever hardcoded in source (CLAUDE.md §5/§11).

# Origin of the FastAPI backend the Vite dev proxy forwards /api and /ws to.
# Mirrors the production Nginx reverse proxy that serves /api /ws / from one origin.
SATYUM_BACKEND_ORIGIN=http://127.0.0.1:8000

# SPLIT DEPLOY ONLY (e.g. Vercel frontend → Railway backend): the absolute backend origin the
# production build calls directly. Set this in the Vercel project's Environment Variables. Leave
# UNSET for local dev (the proxy above handles same-origin /api and /ws).
# VITE_API_BASE_URL=https://your-backend.up.railway.app
