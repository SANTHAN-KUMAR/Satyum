# Keep the backend image lean and the build context small.
**/.venv
**/__pycache__
**/*.pyc
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
.git
node_modules
frontend/node_modules
frontend/dist
# NOTE: frontend/src and /public are intentionally NOT excluded — the frontend image (built from this
# same repo-root context) needs them. The backend image never COPYs frontend/, so it stays lean anyway.
# Dev-only sample binaries are not needed in the images (only samples/trust/ is COPYed explicitly).
samples/pdfs
samples/statements
samples/bundle_consistent
samples/bundle_mismatch
