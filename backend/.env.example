# Satyum backend configuration. Copy to .env (gitignored) for local overrides, or set these as
# environment variables on the host (e.g. Railway service variables). All are read by app/config.py
# with the SATYUM_ prefix. NEVER commit a real .env or any private key (CLAUDE.md §10).

# --- Tier-1 trust anchors -----------------------------------------------------------------
# Directory of PUBLIC trust-anchor certs (PEM/DER) that signatures must chain to. The Docker image
# defaults this to a bundled demo root so the sample signed PDF verifies; override with the real
# public CCA-India root in production.
# SATYUM_TRUST_ANCHOR_DIR=/app/demo-trust

# --- CORS (split-origin deploy only) ------------------------------------------------------
# Comma-separated exact frontend origins allowed to call the API cross-origin. Required when the
# frontend (e.g. Vercel) is on a different host than this backend. Leave empty for same-origin.
# SATYUM_CORS_ALLOW_ORIGINS=https://your-app.vercel.app

# --- Verdict thresholds / tunables (optional; sensible defaults in app/config.py) ----------
# SATYUM_APPROVE_AT=85.0
# SATYUM_REVIEW_AT=60.0
# SATYUM_MAX_FILE_BYTES=26214400

# --- Persistence: durable tamper-evident audit ledger -------------------------------------
# Set DATABASE_ENABLED=true + a reachable DATABASE_URL to persist the hash-chained audit trail in
# Postgres (survives restarts). Default is in-memory. The docker-compose stack sets both for you.
# If the DB is unreachable the backend fails SAFE to in-memory and reports it on /api/health.
# SATYUM_DATABASE_ENABLED=true
# SATYUM_DATABASE_URL=postgresql+psycopg://satyum:satyum@localhost:5432/satyum
